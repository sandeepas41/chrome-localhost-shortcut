{
  "manifest_version": 3,
  "name": "Localhost Shortcut",
  "version": "2.0",
  "description": "Quick access to localhost URLs with keyboard shortcuts",
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Localhost Shortcut"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open localhost URL picker"
    }
  }
}
